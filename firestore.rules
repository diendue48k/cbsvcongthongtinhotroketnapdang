rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, studentId, fullName, createdAt
    //
    // Collection: applications
    // Fields: uid, status, data, createdAt, updatedAt
    //
    // Collection: pending_questions
    // Fields: question, email, status, createdAt, answer
    //
    // Collection: knowledge_base
    // Fields: content
    //
    // Collection: admin_emails
    // Fields: email
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')) ||
        (request.auth.token.email in [
          "levinhdienqt123@gmail.com", 
          "levinhdienthptbenhai@gmail.com", 
          "levinhdien9bthcschuvanan@gmail.com", 
          "levinhdien48kdue@gmail.com"
        ] && request.auth.token.email_verified == true)
      );
    }

    function isApplicationOwner(appData) {
      return isAuthenticated() && (request.auth.uid == appData.userId || request.auth.uid == appData.uid);
    }

    function isAssignedReviewer(appData) {
      return isAuthenticated() && (
        appData.assignedTo == request.auth.uid || 
        (appData.assignedTo is list && request.auth.uid in appData.assignedTo)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student', 'super_admin'];
    }

    function isValidApplication(data) {
      return (data.keys().hasAll(['uid', 'status']) || data.keys().hasAll(['userId', 'status'])) &&
             data.status in ['draft', 'submitted', 'assigned', 'approved', 'rejected', 'writing_hardcopy', 'verifying_background', 'meeting_organized'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /applications/{appId} {
      allow read: if isAuthenticated() && (isApplicationOwner(resource.data) || isAssignedReviewer(resource.data) || isAdmin());
      allow create: if isAuthenticated() && isValidApplication(request.resource.data) && (isApplicationOwner(request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && isValidApplication(request.resource.data) && (isApplicationOwner(resource.data) || isAssignedReviewer(resource.data) || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pending_questions/{questionId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone to ask questions via chatbot
      allow update, delete: if isAdmin();
    }

    match /knowledge_base/{docId} {
      allow read: if true; // Chatbot needs to read knowledge base
      allow write: if isAdmin();
    }

    match /admin_emails/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
